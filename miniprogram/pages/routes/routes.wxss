/* pages/routes/routes.wxss */

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 120rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.filter-arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--text-hint);
}

/* 路线列表 */
.route-list {
  padding: 24rpx 32rpx;
}

.route-item {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.route-cover {
  width: 240rpx;
  height: 280rpx;
  flex-shrink: 0;
}

.route-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.route-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.route-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.route-tags {
  display: flex;
  gap: 8rpx;
}

.route-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.route-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.difficulty {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.difficulty-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.difficulty-bar {
  display: flex;
  gap: 4rpx;
}

.difficulty-segment {
  width: 16rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--border-color);
}

.difficulty-segment.active {
  background: var(--primary-color);
}

.difficulty-segment.active.high {
  background: var(--accent-color);
}

.route-rating {
  font-size: 24rpx;
  color: var(--accent-color);
}

.route-desc {
  font-size: 24rpx;
  color: var(--text-hint);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 空状态 */
.empty-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}
