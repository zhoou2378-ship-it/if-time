/* pages/route-detail/route-detail.wxss */

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 140rpx;
}

/* 头部 */
.header {
  position: relative;
  height: 500rpx;
}

.header-image {
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
}

.header-content {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
}

.route-name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.back-btn {
  position: absolute;
  top: 40rpx;
  left: 32rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
}

/* 区块 */
.section {
  margin: 24rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.info-item {
  text-align: center;
}

.info-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 难度详情 */
.difficulty-detail {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.difficulty-row {
  display: flex;
  align-items: center;
}

.difficulty-row .difficulty-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.difficulty-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.difficulty-bar {
  flex: 1;
  height: 16rpx;
  background: var(--border-color);
  border-radius: 8rpx;
  overflow: hidden;
}

.difficulty-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 8rpx;
}

.difficulty-bar.risk .difficulty-fill {
  background: linear-gradient(90deg, var(--warning-color), var(--danger-color));
}

.difficulty-text {
  width: 80rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: right;
}

/* 路线描述 */
.route-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.feature-list {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.feature-item {
  padding: 12rpx 24rpx;
  background: rgba(45, 90, 39, 0.08);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

/* 交通信息 */
.transport-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.transport-type {
  width: 100rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.transport-info {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 注意事项 */
.notice-item {
  display: flex;
  margin-bottom: 16rpx;
}

.notice-bullet {
  width: 32rpx;
  font-size: 28rpx;
  color: var(--accent-color);
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--border-color);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
}

.action-btn text:first-child {
  font-size: 40rpx;
}

.action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.start-btn {
  flex: 1;
  margin-left: 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 48rpx;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}
