<!--pages/profile/profile.wxml-->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="user-info">
      <open-data type="userNickName"></open-data>
      <text class="user-level">Lv.{{userLevel}} 山野探索者</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section card">
    <text class="section-title">📊 我的足迹</text>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{stats.totalRoutes}}</text>
        <text class="stat-label">完成路线</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.totalDistance}}</text>
        <text class="stat-label">总里程(km)</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.totalElevation}}</text>
        <text class="stat-label">累计爬升(m)</text>
      </view>
    </view>
    
    <view class="achievement-bar">
      <text class="achievement-label">距离下一等级</text>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{stats.progress}}%"></view>
      </view>
      <text class="progress-text">{{stats.progress}}%</text>
    </view>
  </view>

  <!-- 最近完成的路线 -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">📜 最近完成</text>
      <text class="section-more" bindtap="goToHistory">全部 →</text>
    </view>
    
    <view class="history-item" wx:for="{{recentRoutes}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="history-cover" src="{{item.coverImage}}" mode="aspectFill"></image>
      <view class="history-info">
        <text class="history-name">{{item.name}}</text>
        <text class="history-date">{{item.date}}</text>
        <view class="history-stats">
          <text>{{item.distance}}km</text>
          <text>⬆️{{item.elevation}}m</text>
        </view>
      </view>
    </view>
    
    <view class="empty-state" wx:if="{{recentRoutes.length === 0}}">
      <text class="empty-icon">🥾</text>
      <text class="empty-text">还没有完成的路线</text>
      <text class="empty-hint">去探索你的第一条路线吧！</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="section card">
    <view class="menu-item" bindtap="goToFavorites">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goToFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>
</view>
