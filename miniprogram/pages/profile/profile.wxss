/* pages/profile/profile.wxss */

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 120rpx;
}

/* 用户信息 */
.user-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.user-info {
  flex: 1;
}

.user-info open-data {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* 区块 */
.section {
  margin: 24rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 统计 */
.stats-section {
  margin-top: -24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.achievement-bar {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.achievement-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 12rpx;
  background: var(--border-color);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 6rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 历史记录 */
.history-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.history-item:last-child {
  border-bottom: none;
}

.history-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.history-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.history-date {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.history-stats {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-hint {
  display: block;
  font-size: 24rpx;
  color: var(--primary-color);
  margin-top: 12rpx;
}

/* 菜单 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
}
