/* pages/weather/weather.wxss */

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 120rpx;
}

/* 当前天气 */
.weather-main {
  background: linear-gradient(135deg, #4A90D9 0%, #67B8F0 100%);
  padding: 60rpx 40rpx;
  text-align: center;
  color: #fff;
}

.weather-location {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.location-icon {
  font-size: 32rpx;
}

.location-text {
  font-size: 28rpx;
  opacity: 0.9;
}

.weather-display {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.weather-icon {
  width: 120rpx;
  height: 120rpx;
}

.weather-temp {
  font-size: 120rpx;
  font-weight: 200;
  line-height: 1;
}

.weather-condition {
  display: block;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.weather-feels {
  font-size: 26rpx;
  opacity: 0.8;
}

/* 指标网格 */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  margin: -40rpx 32rpx 24rpx;
  position: relative;
  z-index: 1;
}

.metric-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.metric-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.metric-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.metric-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 区块 */
.section {
  margin: 24rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 徒步建议 */
.suggestion-card {
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.suggestion-card.good {
  background: rgba(76, 175, 80, 0.1);
}

.suggestion-card.moderate {
  background: rgba(255, 152, 0, 0.1);
}

.suggestion-card.poor {
  background: rgba(244, 67, 54, 0.1);
}

.suggestion-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.suggestion-level {
  font-size: 28rpx;
  font-weight: 600;
}

.suggestion-card.good .suggestion-level { color: var(--success-color); }
.suggestion-card.moderate .suggestion-level { color: var(--warning-color); }
.suggestion-card.poor .suggestion-level { color: var(--danger-color); }

.suggestion-temp {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.suggestion-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.gear-list {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.gear-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.gear-item {
  display: flex;
  margin-bottom: 12rpx;
}

.gear-bullet {
  width: 32rpx;
  color: var(--primary-color);
}

.gear-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 天气预报 */
.forecast-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.forecast-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.forecast-item:last-child {
  border-bottom: none;
}

.forecast-date {
  width: 140rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.forecast-icon {
  width: 48rpx;
  height: 48rpx;
  margin: 0 20rpx;
}

.forecast-temps {
  display: flex;
  gap: 16rpx;
  font-size: 26rpx;
}

.forecast-high {
  color: var(--text-primary);
  font-weight: 500;
}

.forecast-low {
  color: var(--text-hint);
}

.forecast-hiking {
  margin-left: auto;
}

.hiking-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: rgba(76, 175, 80, 0.1);
  color: var(--success-color);
  border-radius: 12rpx;
}

/* 空气质量 */
.aqi-display {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.aqi-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.aqi-circle.excellent { background: linear-gradient(135deg, #4CAF50, #8BC34A); }
.aqi-circle.good { background: linear-gradient(135deg, #8BC34A, #CDDC39); }
.aqi-circle.moderate { background: linear-gradient(135deg, #FF9800, #FFC107); }
.aqi-circle.poor { background: linear-gradient(135deg, #F44336, #FF5722); }

.aqi-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.aqi-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
}

.aqi-info {
  flex: 1;
}

.aqi-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.aqi-advice {
  font-size: 24rpx;
  color: var(--text-secondary);
}
